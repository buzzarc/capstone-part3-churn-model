import pandas as pd
import numpy as np
from sklearn.ensemble import RandomForestClassifier
from sklearn.model_selection import train_test_split
import joblib

def train_pipeline():
    np.random.seed(42)
    n_samples = 1000
    
    X = pd.DataFrame({
        "recency": np.random.randint(1, 120, n_samples),
        "frequency": np.random.randint(1, 15, n_samples),
        "monetary": np.random.uniform(10, 500, n_samples),
        "support_tickets": np.random.randint(0, 5, n_samples),
        "web_events": np.random.randint(1, 100, n_samples)
    })
    y = np.random.choice([0, 1], size=n_samples, p=[0.7, 0.3])
    
    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)
    
    model = RandomForestClassifier(n_estimators=50, random_state=42)
    model.fit(X_train, y_train)
    
    joblib.dump(model, "model.pkl")
    print("Saved model.pkl artifact successfully.")

if __name__ == "__main__":
    train_pipeline()